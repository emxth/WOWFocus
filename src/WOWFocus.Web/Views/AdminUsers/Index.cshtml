@model List<WOWFocus.Domain.Identity.AppUser>

<h2>Users</h2>
<a class="btn btn-primary mb-2" asp-action="Create">Add User</a>

<table class="table">
    <thead>
        <tr><th>Username</th><th>Roles</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.UserName</td>
                <td>@string.Join(", ", u.Roles)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@u.Id" />
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>