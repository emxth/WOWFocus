@model IReadOnlyList<WOWFocus.Domain.Entities.Student>

@{
    ViewData["Title"] = "Archived Students";
}

<h2>Archived Students</h2>

<a class="btn btn-primary mb-3" asp-action="Index">Back to Active</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Student ID</th>
            <th>Full Name</th>
            <th>Archived At</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.StudentId</td>
                <td>@s.FullName</td>
                <td>@s.ArchivedAt?.ToString("yyyy-MM-dd")</td>
                <td>
                    <form asp-action="Restore" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@s.Id" />
                        <button class="btn btn-sm btn-success">Restore</button>
                    </form>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@s.Id">View</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@s.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>