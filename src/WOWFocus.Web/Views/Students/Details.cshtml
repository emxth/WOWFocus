@model WOWFocus.Domain.Entities.Student

@{
    ViewData["Title"] = "Student Details";

    // Logic to convert the number to a readable string
    string genderDisplay = Model.Gender switch
    {
        1 => "Male",
        2 => "Female",
        _ => "Unknown"
    };
}

<h2>Student Details</h2>

<table class="table">
    <tr><th>Student ID</th><td>@Model.StudentId</td></tr>
    <tr><th>Full Name</th><td>@Model.FullName</td></tr>
    <tr><th>Birth Year</th><td>@Model.BirthYear</td></tr>
    <tr><th>Gender</th><td>@genderDisplay</td></tr>
    <tr><th>Registered Year</th><td>@Model.RegisteredYear</td></tr>
</table>

<a class="btn btn-secondary" asp-action="Index">Back</a>
<a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
